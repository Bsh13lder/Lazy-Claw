{
  "manifest_version": 3,
  "name": "LazyClaw Ref Engine",
  "version": "1.0.0",
  "description": "Ref-ID element mapping for LazyClaw browser automation",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["activeTab"]
}
