# =============================================================================
# LazyClaw Environment Variables
# Copy this file to .env and fill in values: cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Server will not start without these
# ---------------------------------------------------------------------------

# Random string, minimum 32 characters, high entropy. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVER_SECRET=

# ---------------------------------------------------------------------------
# LLM API Keys — At least one required for AI functionality
# ---------------------------------------------------------------------------

# OpenAI (GPT-5, GPT-5-mini)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Haiku, Opus)
ANTHROPIC_API_KEY=

# Optional providers (for ECO mode free routing via mcp-freeride)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
HF_API_KEY=

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------

# Main agent/orchestrator model (default: gpt-5)
BRAIN_MODEL=gpt-5

# Specialist/background job model (default: gpt-5-mini)
WORKER_MODEL=gpt-5-mini

# Fallback if BRAIN_MODEL is unset (default: gpt-5)
DEFAULT_MODEL=gpt-5

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------

# HTTP port (default: 18789)
PORT=18789

# SQLite database directory (default: ./data)
DATABASE_DIR=./data

# Frontend CORS origin (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Logging level: DEBUG, INFO, WARNING, ERROR (default: WARNING)
LOG_LEVEL=WARNING

# Timezone for daily logs and cron jobs (default: UTC)
TIMEZONE=UTC

# ---------------------------------------------------------------------------
# Telegram Bot (optional — needed for Telegram channel)
# ---------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Admin chat ID — first /start claims this automatically
TELEGRAM_ADMIN_CHAT=

# ---------------------------------------------------------------------------
# Registration (optional)
# ---------------------------------------------------------------------------

# Invite token required for registration after first user
REGISTRATION_TOKEN=

# ---------------------------------------------------------------------------
# Browser / CDP (optional — needed for browser skills)
# ---------------------------------------------------------------------------

# Chrome DevTools Protocol port (default: 9222)
CDP_PORT=9222

# Custom browser executable path (auto-detects Brave > Chrome > Chromium)
BROWSER_EXECUTABLE=

# Browser action timeout in seconds (default: 300)
BROWSER_TIMEOUT=300

# Computer/desktop action timeout in seconds (default: 30)
COMPUTER_TIMEOUT=30

# ---------------------------------------------------------------------------
# Agent Tuning (optional)
# ---------------------------------------------------------------------------

# Max tool call iterations per message (default: 50)
MAX_TOOL_ITERATIONS=50

# Single tool execution timeout in seconds (default: 60)
TOOL_TIMEOUT=60

# Heartbeat daemon interval in seconds (default: 60)
HEARTBEAT_INTERVAL=60

# ---------------------------------------------------------------------------
# Remote/Server Mode (optional — for hosted deployments)
# ---------------------------------------------------------------------------

# Enable server mode: true/1/yes (default: disabled)
LAZYCLAW_SERVER_MODE=

# Public hostname for remote browser access
LAZYCLAW_PUBLIC_HOST=

# Enable SSL for remote access
LAZYCLAW_SSL=

# Local Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Activepieces (required when running via docker-compose)
# ---------------------------------------------------------------------------

# 32-character hex key for encrypting Activepieces credentials. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
AP_ENCRYPTION_KEY=

# Secret used to sign Activepieces JWT tokens. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AP_JWT_SECRET=
