# REQUIRED
SERVER_SECRET=change-me-to-a-random-string

# Optional: Default LLM API key (users can set their own in vault)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Server
PORT=18789
DATABASE_DIR=./data
CORS_ORIGIN=http://localhost:3000

# Models (brain = main agent/orchestrator, worker = specialists/background jobs)
BRAIN_MODEL=gpt-5
WORKER_MODEL=gpt-5-mini

# Timezone
TIMEZONE=UTC
